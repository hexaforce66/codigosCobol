       IDENTIFICATION DIVISION.
       PROGRAM-ID. PAYMAIN.
       AUTHOR. LEGO DEMO TEAM.

       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT PAYIN-FILE ASSIGN TO PAYIN
               ORGANIZATION IS LINE SEQUENTIAL.
           SELECT PAYOK-FILE ASSIGN TO PAYOK
               ORGANIZATION IS LINE SEQUENTIAL.
           SELECT PAYREJ-FILE ASSIGN TO PAYREJ
               ORGANIZATION IS LINE SEQUENTIAL.
           SELECT AUDIT-FILE ASSIGN TO AUDITOUT
               ORGANIZATION IS LINE SEQUENTIAL.

       DATA DIVISION.
       FILE SECTION.
       FD  PAYIN-FILE.
       01  PAYIN-LINE             PIC X(90).
       FD  PAYOK-FILE.
       01  PAYOK-LINE             PIC X(120).
       FD  PAYREJ-FILE.
       01  PAYREJ-LINE            PIC X(120).
       FD  AUDIT-FILE.
       01  AUDIT-LINE             PIC X(160).

       WORKING-STORAGE SECTION.
       01  WS-END-FILE            PIC X VALUE 'N'.
           88 END-OF-FILE         VALUE 'Y'.
           88 MORE-RECORDS        VALUE 'N'.
       01  WS-APPROVED-COUNT      PIC 9(7) VALUE ZERO.
       01  WS-REJECTED-COUNT      PIC 9(7) VALUE ZERO.
       01  WS-REVIEW-COUNT        PIC 9(7) VALUE ZERO.
       01  WS-TOTAL-AMOUNT        PIC 9(11)V99 VALUE ZERO.

       COPY PAYMENT.
       COPY CUSTOMER.
       COPY ACCOUNT.
       COPY RETURN_CODES.

       PROCEDURE DIVISION.
       MAIN-PROCESS.
           OPEN INPUT PAYIN-FILE
                OUTPUT PAYOK-FILE PAYREJ-FILE AUDIT-FILE
           PERFORM UNTIL END-OF-FILE
               READ PAYIN-FILE
                   AT END SET END-OF-FILE TO TRUE
                   NOT AT END
                       PERFORM PARSE-PAYMENT
                       PERFORM VALIDATE-PAYMENT
                       PERFORM WRITE-RESULT
               END-READ
           END-PERFORM
           PERFORM WRITE-SUMMARY
           CLOSE PAYIN-FILE PAYOK-FILE PAYREJ-FILE AUDIT-FILE
           STOP RUN.

       PARSE-PAYMENT.
           MOVE PAYIN-LINE(1:12)  TO PAY-ID
           MOVE PAYIN-LINE(13:10) TO PAY-CUSTOMER-ID
           MOVE PAYIN-LINE(23:12) TO PAY-ACCOUNT-ID
           MOVE PAYIN-LINE(35:11) TO PAY-AMOUNT
           MOVE PAYIN-LINE(46:3)  TO PAY-CURRENCY
           MOVE PAYIN-LINE(49:10) TO PAY-CHANNEL
           MOVE PAYIN-LINE(59:12) TO PAY-DESTINATION
           MOVE PAYIN-LINE(71:8)  TO PAY-REQUEST-DATE.

       VALIDATE-PAYMENT.
           MOVE '0000' TO RETURN-CODE
           MOVE 'Payment approved' TO RETURN-MESSAGE
           MOVE ZERO TO RETURN-RISK-SCORE

           CALL 'CUSTVAL' USING PAYMENT-RECORD CUSTOMER-RECORD RETURN-AREA

           IF RET-APPROVED
               CALL 'BALCHK' USING PAYMENT-RECORD ACCOUNT-RECORD RETURN-AREA
           END-IF

           IF RET-APPROVED
               CALL 'RISKSCOR' USING PAYMENT-RECORD CUSTOMER-RECORD
                                    ACCOUNT-RECORD RETURN-AREA
           END-IF

           IF RET-APPROVED OR RET-REVIEW
               ADD PAY-AMOUNT TO WS-TOTAL-AMOUNT
           END-IF.

       WRITE-RESULT.
           CALL 'TXNLOG' USING PAYMENT-RECORD RETURN-AREA AUDIT-LINE
           WRITE AUDIT-LINE

           IF RET-APPROVED
               ADD 1 TO WS-APPROVED-COUNT
               STRING PAY-ID ';APPROVED;' PAY-AMOUNT ';' RETURN-MESSAGE
                   DELIMITED BY SIZE INTO PAYOK-LINE
               WRITE PAYOK-LINE
           ELSE
               IF RET-REVIEW
                   ADD 1 TO WS-REVIEW-COUNT
               ELSE
                   ADD 1 TO WS-REJECTED-COUNT
               END-IF
               STRING PAY-ID ';REJECTED;' RETURN-CODE ';' RETURN-MESSAGE
                   DELIMITED BY SIZE INTO PAYREJ-LINE
               WRITE PAYREJ-LINE
           END-IF.

       WRITE-SUMMARY.
           STRING 'SUMMARY;APPROVED=' WS-APPROVED-COUNT
                  ';REJECTED=' WS-REJECTED-COUNT
                  ';REVIEW=' WS-REVIEW-COUNT
                  ';TOTAL=' WS-TOTAL-AMOUNT
                  DELIMITED BY SIZE INTO AUDIT-LINE
           WRITE AUDIT-LINE.
